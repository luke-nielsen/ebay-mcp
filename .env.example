# eBay application credentials (required).
# Create an app at https://developer.ebay.com/my/keys and copy the values:
#   EBAY_CLIENT_ID     = the "App ID (Client ID)"
#   EBAY_CLIENT_SECRET = the "Cert ID (Client Secret)"
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Environment: "production" (real listings) or "sandbox" (eBay test data).
EBAY_ENVIRONMENT=production

# Marketplace to search. Examples: EBAY_US, EBAY_GB, EBAY_DE, EBAY_AU, EBAY_CA.
EBAY_MARKETPLACE_ID=EBAY_US

# Optional: buyer location for more accurate shipping/delivery estimates.
# EBAY_DELIVERY_COUNTRY=US
# EBAY_DELIVERY_POSTAL_CODE=90210

# Optional network tuning.
# EBAY_TIMEOUT=20
# EBAY_MAX_RETRIES=3
